# 复制为 .env 后填写。不要在仓库中提交真实密钥。

PORT=3000

# GitHub OAuth（可选，用于「使用 GitHub 登录」）
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# AI 上游（可选；也可以在后台给 provider 单独填 api_key）
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# 可选：首次启动自动创建 demo-user 的 API Key。留空则自动生成。
DEFAULT_API_KEY=

# Solana：默认 Devnet 公共 RPC，可换成自己的节点
SOLANA_RPC_URL=https://api.devnet.solana.com

# 金库：Base58 编码的 64 字节密钥（Phantom 导出私钥）。用于收 SOL、付 SOL、付 SAIX
TREASURY_SECRET_KEY=

# SPL Token Mint 地址（先运行 npm run bootstrap-token 生成后填入）
TOKEN_MINT=

# 管理后台（/admin/）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong
SESSION_SECRET=random-long-string-for-session
